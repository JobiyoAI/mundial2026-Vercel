# --- Backend DB mode ---
# Default (empty) uses SQLite file at `data/app.sqlite`.
#
# For Supabase Postgres (recommended for Vercel):
DB_MODE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Optional: force-disable TLS if you're using a local Postgres
# PGSSLMODE=disable

# Optional: serverless-friendly small pool
# PGPOOL_MAX=5

